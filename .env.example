PROJECT_NAME="AI Infographic Generator"
API_V1_STR="/api/v1"

# IMPORTANT: Generate a new secret key for production (e.g. `openssl rand -hex 32`)
SECRET_KEY="replace_me_with_a_secure_random_key"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Postgres config
POSTGRES_SERVER="db"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="infographic_db"
# Only use this if not assembling from pieces above
# SQLALCHEMY_DATABASE_URI="postgresql+asyncpg://postgres:password@db:5432/infographic_db"

REDIS_URL="redis://redis:6379/0"
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

GEMINI_API_KEY=""
OPENAI_API_KEY=""
